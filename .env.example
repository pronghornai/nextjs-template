# Database
# PostgreSQL user used by local development tooling and Docker.
POSTGRES_USER=postgres
# PostgreSQL password (use a strong secret in production).
POSTGRES_PASSWORD=your-db-password
# PostgreSQL database name.
POSTGRES_DB=postgres
# Full database connection string used by the app.
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/postgres

# Authentication
# Secret used to sign auth tokens (at least 32 characters).
BETTER_AUTH_SECRET=your-auth-secret-here
# Public URL where the app is hosted (used for auth callbacks).
BETTER_AUTH_URL=http://localhost:3000
# Google OAuth client ID for social login.
GOOGLE_CLIENT_ID=your-google-client-id
# Google OAuth client secret for social login.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Analytics
# PostHog project API key (safe to expose to the browser).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_public_key
# PostHog host URL.
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Error Tracking
# Sentry DSN for client-side error reporting.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Email
# Default "from" address for transactional emails.
EMAIL_FROM=no-reply@your-domain.com
# SMTP server host.
SMTP_HOST=smtp.your-email-provider.com
# SMTP server port.
SMTP_PORT=587
# SMTP username or API key.
SMTP_USER=your-smtp-username
# SMTP password or API token.
SMTP_PASSWORD=your-smtp-password
